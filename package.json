{
	"name": "video-resizer-2",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"check": "tsc --noEmit",
		"deploy": "npm run dashboard:build && wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"test:run": "vitest run",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"test:smoke": "npx tsx scripts/smoke.ts",
		"test:smoke:container": "npx tsx scripts/smoke.ts --container",
		"test:audit": "npx tsx scripts/transform-audit.ts",
		"test:audit:probe": "npx tsx scripts/transform-audit.ts --probe",
		"test:audit:container": "npx tsx scripts/transform-audit.ts --container",
		"test:browser": "npx playwright test",
		"dashboard:build": "cd dashboard && npx astro build",
		"dashboard:dev": "cd dashboard && npx astro dev"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@cloudflare/workers-types": "^4.20260317.1",
		"@playwright/test": "^1.58.2",
		"typescript": "^6.0.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.76.0"
	},
	"dependencies": {
		"@cloudflare/containers": "^0.2.0",
		"aws4fetch": "^1.0.20",
		"hono": "^4.12.9",
		"zod": "^4.3.6"
	}
}
